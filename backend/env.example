# RBAC-RAG Application Configuration
# Copy this file to .env and update values as needed

# App Configuration
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-secure-secret-key

# Database Configuration
APP_DATABASE_URL=postgresql://user:password@localhost:5432/rbac_rag

# Redis Configuration (for future use)
APP_REDIS_URL=redis://localhost:6379

# Cerbos Configuration
APP_CERBOS_HOST=http://localhost:3592
APP_CERBOS_USE_STUB=true

# RAG Pipeline Configuration
APP_RAG_USE_REAL_SERVICES=false
APP_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
APP_RAG_CHUNK_SIZE=1000
APP_RAG_CHUNK_OVERLAP=200
APP_RAG_FAISS_INDEX_PATH=./data/faiss_index.bin
