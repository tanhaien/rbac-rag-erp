# Backend app settings (prefixed with APP_)
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=please-change-me

# Datastores
APP_DATABASE_URL=postgresql://user:pass@localhost:5432/rbac_rag
APP_REDIS_URL=redis://localhost:6379/0

# Cerbos
APP_CERBOS_HOST=localhost:3593

# RAG
APP_RAG_USE_REAL_SERVICES=false
APP_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
APP_RAG_CHUNK_SIZE=1000
APP_RAG_CHUNK_OVERLAP=200
APP_RAG_FAISS_INDEX_PATH=./faiss.index
